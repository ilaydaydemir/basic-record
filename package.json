{
  "name": "basic-record",
  "version": "1.0.0",
  "description": "Screen recorder with camera bubble",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "co.basicrecord.app",
    "productName": "Basic Record",
    "mac": {
      "category": "public.app-category.video",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Basic Record needs screen access to record your screen.",
        "NSCameraUsageDescription": "Basic Record needs camera access for your bubble.",
        "NSMicrophoneUsageDescription": "Basic Record needs microphone access to record audio."
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
